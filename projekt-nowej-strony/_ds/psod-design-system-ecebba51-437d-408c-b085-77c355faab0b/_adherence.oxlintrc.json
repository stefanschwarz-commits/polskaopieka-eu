{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "design_handoff_psod_website/ui_kit/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Poppins))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Poppins."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|color|key|ref|className|style|children)$/]",
        "message": "<ArrowLink> doesn't accept that prop. Declared props: children, href, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowLink'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:brand|muted)$/]",
        "message": "<ArrowLink> color must be one of 'brand' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|uppercase|href|onClick|disabled|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, uppercase, href, onClick, disabled, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|children|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<FaqItem> doesn't accept that prop. Declared props: question, children, defaultOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilarCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:nr|title|children|empty|emptyLabel|key|ref|className|style|children)$/]",
        "message": "<FilarCard> doesn't accept that prop. Declared props: nr, title, children, empty, emptyLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Highlight> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MythTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:myth|fact|onReveal|key|ref|className|style|children)$/]",
        "message": "<MythTile> doesn't accept that prop. Declared props: myth, fact, onReveal."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|date|image|href|layout|key|ref|className|style|children)$/]",
        "message": "<NewsCard> doesn't accept that prop. Declared props: title, date, image, href, layout."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsCard'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:mini|stacked)$/]",
        "message": "<NewsCard> layout must be one of 'mini' | 'stacked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsletterForm'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|description|placeholder|buttonLabel|rodo|onSubmit|key|ref|className|style|children)$/]",
        "message": "<NewsletterForm> doesn't accept that prop. Declared props: heading, description, placeholder, buttonLabel, rodo, onSubmit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Overline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|as|key|ref|className|style|children)$/]",
        "message": "<Overline> doesn't accept that prop. Declared props: children, tone, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Overline'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:muted|care)$/]",
        "message": "<Overline> tone must be one of 'muted' | 'care'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Placeholder'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|radius|style|key|ref|className|style|children)$/]",
        "message": "<Placeholder> doesn't accept that prop. Declared props: label, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
